# Salin ke .env dan sesuaikan host/user/password dengan stack Postgres Anda (network pgsql_postgres-network).
# Nama host biasanya nama service Postgres di compose pgsql Anda, misalnya `postgres`.
#
# Jika password mengandung karakter khusus (# @ : / ? & = + spasi, dll):
# 1. URL-encode password: `encodeURIComponent("passwordAnda")` (minimal # → %23, @ → %40).
# 2. Bungkus seluruh DATABASE_URL dengan tanda kutip ganda "..." agar # tidak dianggap komentar .env
#
# Contoh: password `a)(IN*cF1UN#U*#8` → `a)(IN*cF1UN%23U*%238`
# DATABASE_URL="postgresql://alfurqon:a)(IN*cF1UN%23U*%238@148.230.96.65:5432/alfurqon_bekasi_id"

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/alfurqon_masjid
JWT_SECRET=ganti-dengan-string-panjang-acak-minimal-32-karakter
JWT_EXPIRES_IN=7d
PORT=3000
NODE_ENV=production
