{
  "info": {
    "_postman_id": "a1f2c8e4-masjid-api-v1",
    "name": "Alfurqon Masjid API",
    "description": "Collection untuk API backend Masjid (auth, CASL, admin users).\n\n- Setelah **Login**, variable `token` terisi otomatis.\n- **Buat user** hanya lewat `POST /admin/users` (token superadmin). Isi `userId` untuk GET detail.\n- Register publik tidak dipakai.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://alfurqonbekasi.web.local/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.ok && json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "}",
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@alfurqonbekasi.id\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "response": []
        },
        {
          "name": "GET Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          },
          "response": []
        },
        {
          "name": "GET Access context (CASL + menu)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/access-context"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET Ping (CASL: read Dashboard)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/admin/ping"
          },
          "response": []
        },
        {
          "name": "Users",
          "item": [
            {
              "name": "GET List users",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/admin/users?page=1&limit=20"
              },
              "response": []
            },
            {
              "name": "GET User by id",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/admin/users/{{userId}}"
              },
              "response": []
            },
            {
              "name": "POST Create user (superadmin)",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"staff@alfurqonbekasi.id\",\n  \"password\": \"password123\",\n  \"fullName\": \"Staff CMS\",\n  \"role\": \"admin\"\n}"
                },
                "url": "{{baseUrl}}/admin/users"
              },
              "response": []
            }
          ]
        }
      ]
    }
  ]
}
