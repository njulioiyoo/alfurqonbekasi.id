# Dev: proxy Vite → backend — path tetap `/api/...` (Express mount `app.use("/api", …)`).
VITE_API_BASE=/api
# Default vite.config tanpa env: http://127.0.0.1:3001 (Docker compose)
# - `npm run dev` di backend/www (tanpa Docker) → set `VITE_PROXY_TARGET=http://127.0.0.1:3000`
# - Docker `backend/docker-compose.yml` → host **3001** → `http://127.0.0.1:3001`
# - Host Traefik (`alfurqonbekasi.web.local`) — wajib rebuild image API bila dapat 404 pada `/api/admin/.../datatable`
VITE_PROXY_TARGET=http://127.0.0.1:3001
# Contoh Traefik:
# VITE_PROXY_TARGET=http://alfurqonbekasi.web.local

# Sesi CMS: JWT di cookie httpOnly `auth-credentials` (bukan localStorage).
# Metronic: bundle di public/metronic/ (sudah di Git) — npm run build saja.
