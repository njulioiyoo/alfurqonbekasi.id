# Dev: proxy Vite → backend — path tetap `/api/...` (Express mount `app.use("/api", …)`).
VITE_API_BASE=/api
# Default vite.config tanpa env: http://127.0.0.1:3000
# - `npm run dev` di backend/www → http://127.0.0.1:3000
# - Docker `backend/docker-compose.yml` → host **3001** → `http://127.0.0.1:3001`
# - Host Traefik (`alfurqonbekasi.web.local`) — wajib rebuild image API bila dapat 404 pada `/api/admin/.../datatable`
VITE_PROXY_TARGET=http://127.0.0.1:3000
# Contoh Traefik:
# VITE_PROXY_TARGET=http://alfurqonbekasi.web.local

# Min 16 karakter — kunci untuk AES-GCM blob sesi di sessionStorage (ter-bundle ke client).
# Ini menyembunyikan token dari tampilan plaintext DevTools; bukan pengganti httpOnly cookie.
VITE_SESSION_SECRET=ganti-dengan-string-panjang-acak-minimal-16
